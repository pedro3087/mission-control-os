# SaaS Factory Mission Control — Environment Variables
# Copy this file to .env.local and fill in the values.
# The app works in DEMO MODE without any of these.

# Vercel API — get from vercel.com/account/tokens
VERCEL_API_TOKEN=

# GitHub — for Guardian PR tracking
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username
GITHUB_REPOS=repo1,repo2,repo3

# Optional: disable demo mode by default (set to "false")
# NEXT_PUBLIC_DEMO_DEFAULT=true
